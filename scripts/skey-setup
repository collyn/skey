#!/bin/bash
# skey-setup: Configure fcitx5 to use skey as the default Vietnamese input method.
# Run this after installing skey: sudo make install && skey-setup

set -e

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/fcitx5"
PROFILE="$CONFIG_DIR/profile"
CONFIG="$CONFIG_DIR/config"

mkdir -p "$CONFIG_DIR"

# ── Write profile: skey-im as default ──
cat > "$PROFILE" << 'EOF'
[Groups/0]
# Group Name
Name=Default
# Layout
Default Layout=us
# Default Input Method
DefaultIM=skey-im

[Groups/0/Items/0]
# Name
Name=keyboard-us
# Layout
Layout=

[Groups/0/Items/1]
# Name
Name=skey-im
# Layout
Layout=

[GroupOrder]
0=Default
EOF

echo "✓ Profile written: skey-im set as default IM"

# ── Patch config: ActiveByDefault + ShareInputState ──
if [ -f "$CONFIG" ]; then
    # Update existing config
    sed -i 's/^ActiveByDefault=.*/ActiveByDefault=True/' "$CONFIG"
    sed -i 's/^ShareInputState=.*/ShareInputState=All/' "$CONFIG"
    echo "✓ Config updated: ActiveByDefault=True, ShareInputState=All"
else
    # Create minimal config
    cat > "$CONFIG" << 'EOF'
[Hotkey]
EnumerateWithTriggerKeys=True
EnumerateSkipFirst=False

[Hotkey/TriggerKeys]
0=Control+space

[Hotkey/AltTriggerKeys]
0=Shift_L

[Behavior]
ActiveByDefault=True
ShareInputState=All
PreeditEnabledByDefault=True
ShowInputMethodInformation=True
PreloadInputMethod=True
EOF
    echo "✓ Config created with skey defaults"
fi

# ── Auto-detect environment ──
detect_shell() {
    local sh
    sh=$(basename "${SHELL:-/bin/bash}")
    case "$sh" in
        zsh)  echo "zsh" ;;
        fish) echo "fish" ;;
        *)    echo "bash" ;;
    esac
}

detect_de() {
    # Hyprland, Sway, Niri: detected by their compositor socket
    if [ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]; then echo "Hyprland"; return; fi
    if [ -n "${SWAYSOCK:-}" ]; then echo "Sway"; return; fi
    if [ -n "${NIRI_SOCKET:-}" ]; then echo "Niri"; return; fi
    case "${XDG_CURRENT_DESKTOP:-}" in
        KDE|kde|KDE-Plasma|plasma) echo "KDE Plasma" ;;
        GNOME|gnome|GNOME-Classic) echo "GNOME" ;;
        *) echo "${XDG_CURRENT_DESKTOP:-unknown}" ;;
    esac
}

USER_SHELL=$(detect_shell)
USER_DE=$(detect_de)
SESSION_TYPE="${XDG_SESSION_TYPE:-x11}"

echo "  Shell: $USER_SHELL  DE: $USER_DE  Session: $SESSION_TYPE"

# ── Determine required environment variables ──
# KDE Plasma on Wayland: KWin handles GTK/Qt natively via zwp_input_method_v2,
# but many apps (AppImages, flatpaks, Qt apps without wayland plugin) still
# need the full set.  GNOME/Sway: GTK uses text-input natively, Qt needs
# IM module + QT_IM_MODULES for Qt6.  X11/others: full set.
if [ "$SESSION_TYPE" = "wayland" ]; then
    case "$USER_DE" in
        "KDE Plasma")
            ENV_VARS="GTK_IM_MODULE=fcitx QT_IM_MODULE=fcitx5 XMODIFIERS=@im=fcitx SDL_IM_MODULE=fcitx GLFW_IM_MODULE=ibus"
            ;;
        GNOME|Sway)
            ENV_VARS="XMODIFIERS=@im=fcitx QT_IM_MODULE=fcitx5 QT_IM_MODULES=wayland;fcitx GLFW_IM_MODULE=ibus"
            ;;
        *)
            ENV_VARS="GTK_IM_MODULE=fcitx QT_IM_MODULE=fcitx5 XMODIFIERS=@im=fcitx SDL_IM_MODULE=fcitx GLFW_IM_MODULE=ibus"
            ;;
    esac
else
    ENV_VARS="GTK_IM_MODULE=fcitx QT_IM_MODULE=fcitx5 XMODIFIERS=@im=fcitx SDL_IM_MODULE=fcitx GLFW_IM_MODULE=ibus"
fi

# ── Helper: safely update a shell config file ──
# Inserts or replaces a guarded block so existing user config is preserved.
# Arguments: $1 = file path, $2 = content (multi-line, with export prefix).
upsert_shell_env() {
    local file="$1"
    local content="$2"
    local begin_marker="# >>> fcitx5-skey >>>"
    local end_marker="# <<< fcitx5-skey <<<"

    if [ -f "$file" ] && grep -qF "$begin_marker" "$file" 2>/dev/null; then
        # Update existing block: replace everything between markers.
        local tmpfile
        tmpfile=$(mktemp)
        awk -v begin="$begin_marker" -v end="$end_marker" -v repl="$content" '
            BEGIN { skip=0; replaced=0 }
            $0 == begin { print; print repl; skip=1; replaced=1; next }
            $0 == end   { skip=0 }
            !skip { print }
        ' "$file" > "$tmpfile"
        mv "$tmpfile" "$file"
    else
        # Append new block at the end.
        {
            [ -f "$file" ] && cat "$file"
            echo ""
            echo "$begin_marker"
            printf '%s\n' "$content"
            echo "$end_marker"
        } > "${file}.skey-tmp"
        mv "${file}.skey-tmp" "$file"
    fi
}

# ── Write environment files ──
ENVDIR="$HOME/.config/environment.d"
ENVFILE="$ENVDIR/fcitx5-skey.conf"

# systemd environment.d (KEY=VALUE format, no export).
# Respected by KDE, GNOME, Sway, and most systemd-based Wayland compositors.
mkdir -p "$ENVDIR"
{
    echo "# fcitx5-skey"
    for var in $ENV_VARS; do echo "$var"; done
} > "$ENVFILE"
echo "✓ systemd environment.d: $ENVFILE"

# Build export lines for shell configs
EXPORT_LINES=""
for var in $ENV_VARS; do
    EXPORT_LINES="${EXPORT_LINES}export $var
"
done

# Shell config and .profile — use upsert to preserve existing content
case "$USER_SHELL" in
    bash)
        upsert_shell_env "$HOME/.bash_profile" "$EXPORT_LINES"
        echo "✓ Shell config: $HOME/.bash_profile"
        ;;
    zsh)
        upsert_shell_env "$HOME/.zprofile" "$EXPORT_LINES"
        echo "✓ Shell config: $HOME/.zprofile"
        ;;
    fish)
        FISH_CONF="$HOME/.config/fish/config.fish"
        mkdir -p "$(dirname "$FISH_CONF")"
        FISH_LINES="if status is-login"
        for var in $ENV_VARS; do
            name="${var%%=*}"
            value="${var#*=}"
            FISH_LINES="${FISH_LINES}
    set -Ux $name $value"
        done
        FISH_LINES="${FISH_LINES}
end"
        upsert_shell_env "$FISH_CONF" "$FISH_LINES"
        echo "✓ Shell config: $FISH_CONF"
        ;;
esac

# ~/.profile — sourced by most display managers (SDDM, GDM, LightDM) and
# login shells.  Shell-specific configs (.bash_profile, .zprofile) take
# precedence for interactive shells, but DMs often only read .profile.
upsert_shell_env "$HOME/.profile" "$EXPORT_LINES"
echo "✓ Login profile: $HOME/.profile"

# KDE Plasma: session startup scripts — the canonical place for per-session
# env vars on KDE.  Sourced by startplasma before launching kwin and apps.
# This is a dedicated file owned by skey — safe to overwrite.
if [ "$USER_DE" = "KDE Plasma" ]; then
    KDE_ENVDIR="$HOME/.config/plasma-workspace/env"
    mkdir -p "$KDE_ENVDIR"
    KDE_ENVFILE="$KDE_ENVDIR/fcitx5-skey.sh"
    {
        echo "# fcitx5-skey"
        for var in $ENV_VARS; do echo "export $var"; done
    } > "$KDE_ENVFILE"
    chmod +x "$KDE_ENVFILE"
    echo "✓ KDE session env: $KDE_ENVFILE"
fi

# Also write .xprofile for X11 display managers and legacy support
upsert_shell_env "$HOME/.xprofile" "$EXPORT_LINES"
echo "✓ X11 fallback: $HOME/.xprofile"

# Source immediately for current session
for var in $ENV_VARS; do
    export "${var%%=*}=${var#*=}"
done
echo "✓ Env vars sourced for current session"

# systemd user session — the most reliable method for systemd-based
# compositors (KDE, GNOME, Sway).  Survives logout/login and is picked
# up by all apps launched via the session, including flatpaks and AppImages.
if command -v systemctl >/dev/null 2>&1 && systemctl --user show-environment >/dev/null 2>&1; then
    for var in $ENV_VARS; do
        name="${var%%=*}"
        value="${var#*=}"
        systemctl --user set-environment "$name=$value" 2>/dev/null || true
    done
    echo "✓ systemd user environment set"
fi

# ── Wayland: disable classicui (XEmbed tray broken on Wayland) ──
if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
    ADDON_DIR="$CONFIG_DIR/addon"
    mkdir -p "$ADDON_DIR"
    cat > "$ADDON_DIR/classicui.conf" << 'CLASSICUIOFF'
[Addon]
Enabled=False
CLASSICUIOFF
    echo "✓ Disabled classicui (XEmbed tray doesn't work on Wayland)"

    # Ensure notificationitem is enabled for native SNI tray
    cat > "$ADDON_DIR/notificationitem.conf" << 'SNION'
[Addon]
Enabled=True
SNION
    echo "✓ Ensured notificationitem (native SNI tray) is enabled"
fi

# ── Restart fcitx5 if running ──
# On Wayland, the compositor (KWin/Mutter) connects directly to fcitx5 via
# zwp_input_method_v2.  When fcitx5 restarts, the compositor does NOT
# automatically reconnect — the virtual keyboard silently falls back to
# "None", breaking Vietnamese input until the user manually re-selects
# fcitx5 in system settings.  We fix this by toggling KWin's VirtualKeyboard
# enabled property via D-Bus, which forces a protocol reconnect.
if pidof fcitx5 > /dev/null 2>&1; then
    fcitx5 -r -d 2>/dev/null &
    sleep 1  # give fcitx5 time to start and accept D-Bus connections
    echo "✓ fcitx5 restarted"

    # ── Wayland: re-trigger compositor virtual keyboard binding ──
    if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
        case "${XDG_CURRENT_DESKTOP:-}" in
            KDE|kde|KDE-Plasma|plasma)
                # KWin: toggle VirtualKeyboard enabled via D-Bus to force
                # compositor to tear down and re-establish the
                # zwp_input_method_v2 connection to the new fcitx5 process.
                QDBUS="qdbus6"
                if ! command -v qdbus6 >/dev/null 2>&1; then
                    QDBUS="qdbus"  # fallback for Plasma 5
                fi
                $QDBUS org.kde.KWin /VirtualKeyboard org.freedesktop.DBus.Properties.Set \
                    org.kde.kwin.VirtualKeyboard enabled false 2>/dev/null || true
                sleep 0.6
                $QDBUS org.kde.KWin /VirtualKeyboard org.freedesktop.DBus.Properties.Set \
                    org.kde.kwin.VirtualKeyboard enabled true 2>/dev/null || true
                echo "✓ KWin virtual keyboard reconnected to fcitx5"
                ;;
            GNOME|gnome|GNOME-Classic)
                # GNOME Shell: re-apply input sources to trigger reconnect
                if command -v gsettings >/dev/null 2>&1; then
                    CURRENT_SRC=$(gsettings get org.gnome.desktop.input-sources sources 2>/dev/null || true)
                    if [ -n "$CURRENT_SRC" ]; then
                        # Toggle off then on to force Shell to reconnect
                        gsettings set org.gnome.desktop.input-sources sources "[]" 2>/dev/null || true
                        sleep 0.5
                        gsettings set org.gnome.desktop.input-sources sources "$CURRENT_SRC" 2>/dev/null || true
                        echo "✓ GNOME Shell input sources refreshed"
                    fi
                fi
                ;;
            *)
                echo "⚠ Wayland detected ($XDG_CURRENT_DESKTOP)."
                echo "  If Vietnamese input stops working, manually re-select"
                echo "  'Fcitx 5' in System Settings → Keyboard → Virtual Keyboard."
                ;;
        esac
    fi
else
    echo "ℹ fcitx5 is not running. Start it with: fcitx5 -d"
fi

echo ""
echo "Done! skey is now the default Vietnamese input method."
echo "Toggle with Ctrl+Space. Settings: fcitx5-configtool"
echo ""
if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
    echo "⚠  Wayland note: If some apps still don't work after this,"
    echo "   log out and back in to fully refresh the session."
fi
