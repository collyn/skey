#!/bin/bash
# skey-setup: Configure fcitx5 to use skey as the default Vietnamese input method.
# Run this after installing skey: sudo make install && skey-setup

set -e

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/fcitx5"
PROFILE="$CONFIG_DIR/profile"
CONFIG="$CONFIG_DIR/config"

mkdir -p "$CONFIG_DIR"

# ── Write profile: skey-im as default ──
cat > "$PROFILE" << 'EOF'
[Groups/0]
# Group Name
Name=Default
# Layout
Default Layout=us
# Default Input Method
DefaultIM=skey-im

[Groups/0/Items/0]
# Name
Name=keyboard-us
# Layout
Layout=

[Groups/0/Items/1]
# Name
Name=skey-im
# Layout
Layout=

[GroupOrder]
0=Default
EOF

echo "✓ Profile written: skey-im set as default IM"

# ── Patch config: ActiveByDefault + ShareInputState ──
if [ -f "$CONFIG" ]; then
    # Update existing config
    sed -i 's/^ActiveByDefault=.*/ActiveByDefault=True/' "$CONFIG"
    sed -i 's/^ShareInputState=.*/ShareInputState=All/' "$CONFIG"
    echo "✓ Config updated: ActiveByDefault=True, ShareInputState=All"
else
    # Create minimal config
    cat > "$CONFIG" << 'EOF'
[Hotkey]
EnumerateWithTriggerKeys=True
EnumerateSkipFirst=False

[Hotkey/TriggerKeys]
0=Control+space

[Hotkey/AltTriggerKeys]
0=Shift_L

[Behavior]
ActiveByDefault=True
ShareInputState=All
PreeditEnabledByDefault=True
ShowInputMethodInformation=True
PreloadInputMethod=True
EOF
    echo "✓ Config created with skey defaults"
fi

# ── Export environment variables for X11 and Wayland ──
XPROFILE="$HOME/.xprofile"
ENVDIR="$HOME/.config/environment.d"
ENVFILE="$ENVDIR/fcitx5-skey.conf"

ENV_BLOCK="# fcitx5-skey: required for input method to work in all applications
export GTK_IM_MODULE=fcitx5
export QT_IM_MODULE=fcitx5
export XMODIFIERS=@im=fcitx5
export SDL_IM_MODULE=fcitx5
export GLFW_IM_MODULE=ibus"

# Wayland: systemd environment.d (respected by KDE, GNOME, etc.)
mkdir -p "$ENVDIR"
if [ -f "$ENVFILE" ]; then
    sed -i '/fcitx5-skey/d' "$ENVFILE"
fi
echo "$ENV_BLOCK" > "$ENVFILE"
echo "✓ Wayland environment: $ENVFILE"

# X11: ~/.xprofile (sourced by display managers)
echo "$ENV_BLOCK" > "$XPROFILE"
echo "✓ X11 environment: $XPROFILE"

# Source immediately for current session
export GTK_IM_MODULE=fcitx5
export QT_IM_MODULE=fcitx5
export XMODIFIERS=@im=fcitx5
export SDL_IM_MODULE=fcitx5
export GLFW_IM_MODULE=ibus

# ── Wayland: disable classicui (XEmbed tray broken on Wayland) ──
if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
    ADDON_DIR="$CONFIG_DIR/addon"
    mkdir -p "$ADDON_DIR"
    cat > "$ADDON_DIR/classicui.conf" << 'CLASSICUIOFF'
[Addon]
Enabled=False
CLASSICUIOFF
    echo "✓ Disabled classicui (XEmbed tray doesn't work on Wayland)"

    # Ensure notificationitem is enabled for native SNI tray
    cat > "$ADDON_DIR/notificationitem.conf" << 'SNION'
[Addon]
Enabled=True
SNION
    echo "✓ Ensured notificationitem (native SNI tray) is enabled"
fi

# ── Restart fcitx5 if running ──
# On Wayland, the compositor (KWin/Mutter) connects directly to fcitx5 via
# zwp_input_method_v1.  When fcitx5 restarts, the compositor does NOT
# automatically reconnect — the virtual keyboard silently falls back to
# "None", breaking Vietnamese input until the user manually re-selects
# fcitx5 in system settings.  We fix this by re-applying the compositor's
# input method preference after restart, which forces a reconnect.
if pidof fcitx5 > /dev/null 2>&1; then
    fcitx5 -r -d 2>/dev/null &
    sleep 1  # give fcitx5 time to start and accept D-Bus connections
    echo "✓ fcitx5 restarted"

    # ── Wayland: re-trigger compositor virtual keyboard binding ──
    if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
        case "${XDG_CURRENT_DESKTOP:-}" in
            KDE|kde|KDE-Plasma|plasma)
                # KWin: re-apply InputMethod setting to force reconnect
                kwriteconfig5 --file kwinrc --group Wayland \
                    --key InputMethod /usr/share/applications/fcitx5-wayland-launcher.desktop 2>/dev/null || true
                # Notify KWin to reload (KWin's D-Bus reloadConfig only available in 5.27+)
                dbus-send --type=signal /KWin org.kde.KWin.reloadConfig 2>/dev/null || true
                echo "✓ KWin virtual keyboard reconnected to fcitx5"
                ;;
            GNOME|gnome|GNOME-Classic)
                # GNOME Shell: re-apply input sources to trigger reconnect
                if command -v gsettings >/dev/null 2>&1; then
                    CURRENT_SRC=$(gsettings get org.gnome.desktop.input-sources sources 2>/dev/null || true)
                    if [ -n "$CURRENT_SRC" ]; then
                        # Toggle off then on to force Shell to reconnect
                        gsettings set org.gnome.desktop.input-sources sources "[]" 2>/dev/null || true
                        sleep 0.5
                        gsettings set org.gnome.desktop.input-sources sources "$CURRENT_SRC" 2>/dev/null || true
                        echo "✓ GNOME Shell input sources refreshed"
                    fi
                fi
                ;;
            *)
                echo "⚠ Wayland detected ($XDG_CURRENT_DESKTOP)."
                echo "  If Vietnamese input stops working, manually re-select"
                echo "  'Fcitx 5' in System Settings → Keyboard → Virtual Keyboard."
                ;;
        esac
    fi
else
    echo "ℹ fcitx5 is not running. Start it with: fcitx5 -d"
fi

echo ""
echo "Done! skey is now the default Vietnamese input method."
echo "Toggle with Ctrl+Space. Settings: fcitx5-configtool"
echo ""
if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
    echo "⚠  Wayland note: If some apps still don't work after this,"
    echo "   log out and back in to fully refresh the session."
fi
